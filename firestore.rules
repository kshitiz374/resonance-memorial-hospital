rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Bootstrap admin check: Allow the developer email to act as admin
      return isSignedIn() && (
        request.auth.token.email == "kshitiztiwari374@gmail.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid && 
             data.email is string && 
             data.email.size() > 0;
    }

    function isValidBooking(data) {
      return (data.userId == request.auth.uid || isAdmin()) &&
             data.fullName is string && data.fullName.size() > 0 &&
             data.department is string && data.department.size() > 0 &&
             data.date is string &&
             data.time is string;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin'])) || isAdmin();
    }

    match /bookings/{bookingId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if (isSignedIn() && isValidBooking(request.resource.data));
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && isValidBooking(request.resource.data));
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
  }
}
